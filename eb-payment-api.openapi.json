                        }
                      },
                      "required": [
                        "pageNumber",
                        "pageSize",
                        "sort",
                        "offset",
                        "paged",
                        "unpaged"
                      ]
                    }
                  },
                  "required": [
                    "content",
                    "number",
                    "size",
                    "totalElements",
                    "totalPages",
                    "last",
                    "first",
                    "pageable",
                    "sort",
                    "numberOfElements",
                    "empty"
