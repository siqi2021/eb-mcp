            "schema": {
              "type": "string",
              "default": "{{$string.uuid}}"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "startDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "endDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "queryObject": {
                    "type": "string",
                    "enum": [
                      "usage-event-insights-summary",
                      "usage-event-insights-detail",
                      "revenue-insights-summary",
                      "revenue-insights-detail",
                      "bucket-transaction",
                      "usage-event",
                      "aggregated-usage",
                      "payment-query-list"
                    ]
                  },
                  "filters": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "fieldName": {
                          "type": "string",
                          "enum": [
                            "transactionId",
                            "customerIdentifier",
                            "paymentGatewayType",
                            "status"
                          ]
                        },
                        "fieldValues": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {}
                          }
                        }
                      }
                    }
                  }
                },
                "required": [
                  "endDate",
                  "queryObject",
                  "startDate"
                ]
              },
              "example": {
                "startDate": "2026-01-01",
                "endDate": "2026-03-01",
                "queryObject": "payment-query-list",
                "filters": [
                  {
                    "fieldName": "paymentGatewayType",
                    "fieldValues": [
                      "stripe-connect"
                    ]
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "content": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "title": "Unique ID in the payment table",
                            "description": "id of this record"
                          },
                          "gatewayLink": {
                            "type": "string",
                            "title": "Gateway payment link",
                            "description": "This link can be used to initiate payment on the corresponding payment platform (for WeChat Pay, the frontend needs to directly convert the address into a QR code)"
                          },
                          "customerIdentifier": {
                            "type": "string",
                            "title": "Customer identifier",
                            "description": "Can be phone number/email/openId, etc.",
                            "nullable": true
                          },
                          "transactionId": {
                            "type": "string",
                            "title": "Transaction ID",
                            "description": "payment transaction id"
                          },
                          "description": {
                            "type": "string",
                            "title": "Transaction information",
                            "description": "Description information for initiating payment"
                          },
                          "amount": {
                            "type": "string",
                            "title": "Payment amount",
                            "description": "Payment amount"
                          },
                          "currency": {
                            "type": "string",
                            "title": "Currency unit",
                            "description": "Currency code, following ISO-4217 standard"
                          },
                          "paymentGateway": {
                            "type": "string",
                            "title": "Payment gateway",
                            "description": "If payment is completed, returns the earliest successfully paid gateway",
                            "enum": [
                              "stripe-connect",
                              "alipay-page",
                              "wechat-pay-native"
                            ]
                          },
                          "dateTime": {
                            "type": "string",
                            "title": "Creation time",
                            "description": "Creation time"
                          },
                          "status": {
                            "type": "string",
                            "title": "Payment status",
                            "enum": [
                              "pending",
                              "processing",
                              "completed-with-success",
                              "completed-with-failure",
                              "expired",
                              "closed",
                              "refunded"
                            ]
                          },
                          "refundedAmount": {
                            "type": "string",
                            "title": "Refund amount",
                            "description": "Refund amount"
                          }
                        },
                        "required": [
                          "gatewayLink",
                          "id"
                        ]
                      }
                    },
                    "number": {
                      "type": "integer",
                      "title": "Page number"
                    },
                    "size": {
                      "type": "integer",
                      "title": "Number of items per page"
                    },
                    "totalElements": {
                      "type": "integer",
                      "title": "Total number of items"
                    },
                    "totalPages": {
                      "type": "integer",
                      "title": "Total number of pages"
                    },
                    "last": {
                      "type": "boolean"
                    },
                    "first": {
                      "type": "boolean"
                    },
                    "numberOfElements": {
                      "type": "integer"
                    },
                    "empty": {
                      "type": "boolean"
                    },
                    "sort": {
                      "type": "object",
                      "properties": {
                        "empty": {
                          "type": "boolean"
                        },
                        "sorted": {
                          "type": "boolean"
                        },
                        "unsorted": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "empty",
                        "sorted",
                        "unsorted"
                      ]
                    },
                    "pageable": {
                      "type": "object",
                      "properties": {
                        "pageNumber": {
                          "type": "integer"
                        },
                        "pageSize": {
                          "type": "integer"
                        },
                        "offset": {
                          "type": "integer"
                        },
                        "paged": {
                          "type": "boolean"
                        },
                        "unpaged": {
                          "type": "boolean"
                        },
                        "sort": {
                          "type": "object",
                          "properties": {
                            "empty": {
                              "type": "boolean"
                            },
                            "sorted": {
                              "type": "boolean"
                            },
                            "unsorted": {
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "empty",
                            "sorted",
                            "unsorted"
